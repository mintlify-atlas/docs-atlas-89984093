  "keyFeatures": [
    "Area, fullscreen, and window screenshot capture via ScreenCaptureKit",
    "Screen recording to MP4 and GIF with system audio and microphone support",
    "Webcam picture-in-picture with 4 shapes (circle, square, landscape, portrait)",
    "Annotation editor with arrows, shapes, freehand, text, blur/pixelate, and counter tools",
    "Screenshot beautification with background, padding, rounded corners, and shadow",
    "Instant and visual OCR powered by Apple Vision framework",
    "Pin screenshots as always-on-top floating windows with click-through mode",
    "Fully configurable global keyboard shortcuts",
    "Modular SPM architecture with 8 independent, reusable Swift packages",
    "Localization: English, Simplified Chinese, Japanese, Korean"
  ],
  "publicApiSurface": [
    "ScreenCaptureManager.captureFullscreen(displayID:)",
    "ScreenCaptureManager.captureWindow(windowID:includeShadow:)",
    "ScreenCaptureManager.captureArea(rect:displayID:)",
    "CaptureMode (area, fullscreen, window, scrolling)",
    "CaptureResult (image, mode, captureRect, windowName, appName, displayID)",
    "ScreenRecorder.startRecording(config:)",
    "ScreenRecorder.pause()",
    "ScreenRecorder.resume()",
    "ScreenRecorder.stopRecording()",
    "RecordingState (idle, preparing, recording, paused, stopping)",
    "AnnotationDocument.addObject(_:)",
    "AnnotationDocument.removeObject(id:)",
    "AnnotationDocument.undo()",
    "AnnotationDocument.redo()",
    "AnnotationObject (ArrowObject, RectangleObject, EllipseObject, TextObject, FreehandObject, PixelateObject, CounterObject, CropObject)",
    "ExportFormat (mp4, gif)",
    "ExportQuality (maximum, social, web)",
    "ExportOptions(format:quality:destination:)",
    "AppSettings (all user-configurable preferences backed by UserDefaults)",
    "PermissionManager (screen recording, camera, microphone, accessibility)"
  ]
